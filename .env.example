# --- Required ---

# Discord bot token from https://discord.com/developers/applications (Bot -> Reset Token)
DISCORD_BOT_TOKEN=

# Your PERSONAL Anthropic API key from https://platform.claude.com
# Do NOT use credentials tied to a Claude subscription seat.
ANTHROPIC_API_KEY=

# --- Repo access ---

# Path to a local clone of https://github.com/sdercolin/vlabeler (main branch)
VLABELER_REPO_PATH=../vlabeler

# Optional: a second clone checked out on the dev branch, for questions about unreleased changes.
# Optional: a directory where GitHub release notes are synced to releases.md for the bot to read.
# Both are set automatically in the Docker image (/data/vlabeler-dev, /data/releases);
# leave empty elsewhere to disable.
#VLABELER_DEV_REPO_PATH=
#RELEASES_DIR=

# Run `git pull --ff-only` in the repo clone every N minutes (0 = disabled)
REPO_SYNC_MINUTES=30

# --- Model & cost controls ---

# claude-sonnet-5 = balanced (default), claude-haiku-4-5 = cheapest, claude-opus-4-1 = strongest
CLAUDE_MODEL=claude-sonnet-5

# Max agentic turns (tool-use round trips) per question
MAX_TURNS=25

# Hard cost cap per question, in USD
MAX_BUDGET_USD_PER_QUERY=0.50

# --- Discord behavior ---

# Comma-separated channel IDs the bot listens in. Empty = respond to mentions in any channel.
ALLOWED_CHANNEL_IDS=

# Seconds a user must wait between questions
USER_COOLDOWN_SECONDS=30

# Max questions being answered at the same time
MAX_CONCURRENT_QUERIES=2
